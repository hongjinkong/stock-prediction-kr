# Python 생성 파일 제외
__pycache__/
*.pyc

# 모델 가중치 및 로컬 물리 파일 제외 (용량 초과 및 보안 방지)
*.pt
*.pkl
*.txt
*.h5

# 가상환경 및 설정 파일 제외
.ipynb_checkpoints/
.venv/
venv/
.env

# .gitignore 파일 생성
with open('.gitignore', 'w') as f:
    f.write('''
# 데이터 및 캐시 제외
*.csv
*.xlsx
__pycache__/
.ipynb_checkpoints/
.DS_Store
# 모델 가중치 파일
*.pth
*.pkl
''')